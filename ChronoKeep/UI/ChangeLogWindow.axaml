<Window xmlns="https://github.com/avaloniaui"
        xmlns:changelog="using:Chronokeep.Objects.Changelog"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="Chronokeep.UI.ChangeLogWindow"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen"
        Title="Change Event"
        Width="600"
        Height="500"
        MinWidth="600"
        MinHeight="500"
        Topmost="True"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="55" />
        </Grid.RowDefinitions>
		<ListBox Grid.Row="0"
                 Name="logList"
                 Margin="10,30,10,0"
                 CornerRadius="8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Expander HorizontalAlignment="Stretch" IsExpanded="{Binding IsExpanded}" x:DataType="changelog:Entry">
                        <Expander.Header>
                            <TextBlock Text="{Binding Version}" x:DataType="changelog:Entry" HorizontalAlignment="Center" Margin="0,0,-45,0" FontSize="20"/>
                        </Expander.Header>
                        <StackPanel>
                            <TextBlock Text="Changes" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,15"/>
                            <ListBox ItemsSource="{Binding ChangesList}" x:DataType="changelog:Entry"/>
                            <TextBlock Text="Fixes" FontSize="18" HorizontalAlignment="Center" Margin="0,15,0,15"/>
                            <ListBox ItemsSource="{Binding FixesList}" x:DataType="changelog:Entry"/>
                        </StackPanel>
                    </Expander> 
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <ToggleSwitch Name="autoChangelogToggleSwitch"
                          FontSize="14"
                          OnContent=""
                          OffContent=""
                          Margin="10,-7,-7,-7"
                          HorizontalAlignment="Left"
                          VerticalContentAlignment="Center"/>
            <Label Content="Show changelog after update"
                   VerticalAlignment="Center"/>
            <Button Name="cancelButton"
                    Content="Done"
                    Click="CancelButton_Click"
                    Width="150"
                    Height="35"
                    FontSize="16"
                    Margin="10,0,10,0"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
