<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="Chronokeep.UI.Import.ImportFileWindow"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Title="Import File"
        Height="600"
        Width="500"
        MinWidth="450"
        Closing="Window_Closing">
    <Window.Styles>
		<Style Selector="Button">
			<Setter Property="Height" Value="35"/>
			<Setter Property="Width" Value="100"/>
			<Setter Property="Margin" Value="0,10,10,5"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Styles>
    <Grid Margin="0,30,0,0" Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" VerticalAlignment="Center" ColumnDefinitions="*,110,110">
            <ComboBox Grid.Column="0"
                      Name="SheetsBox"
                      SelectionChanged="SheetsBox_SelectionChanged"
                      Height="35"
                      Width="250"
                      TabIndex="1"
                      Margin="10,10,10,5"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Stretch"
                      VerticalContentAlignment="Center"
                      />
            <Button Grid.Column="1"
                    Name="Done"
                    Content="Next"
                    Click="Done_Click"
                    FontSize="16"
                    />
            <Button Grid.Column="2"
                    Name="Cancel"
                    Content="Cancel"
                    Click="Cancel_Click"
                    FontSize="16"
                    />
        </Grid>
        <UserControl Grid.Row="1"
                     Name="Frame"
                     IsTabStop="False"
                     CornerRadius="8"
                     />
    </Grid>
</Window>
