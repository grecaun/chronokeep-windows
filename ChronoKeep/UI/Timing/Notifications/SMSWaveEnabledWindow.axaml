<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:Chronokeep.UI.Timing.Notifications"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="230"
        x:Class="Chronokeep.UI.Timing.Notifications.SMSWaveEnabledWindow"
        Background="{DynamicResource PrimaryBackground}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen"
        Title="SMS Waves"
        Width="230"
        SizeToContent="Height"
        Topmost="True"
        Closing="Window_Closing">
    <Grid Margin="0,30,0,0" Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Name="MainPanel">
            <ListBox Name="WaveList"
                        Margin="15,0"
                        BorderThickness="0"
                        KeyboardNavigation.TabNavigation="Continue">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ToggleSwitch Name="SmsEnabledSwitch"
                                            DockPanel.Dock="Right"
                                            IsChecked="{Binding SMSEnabled}"
                                            Margin="0,-7"
                                            OnContent=""
                                            OffContent=""
                                            VerticalAlignment="Center"
                                            x:DataType="local:WaveSMS"/>
                            <TextBlock Text="{Binding WaveName}" Margin="5" x:DataType="local:WaveSMS"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Margin="10,10,10,15"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button Name="Set"
                    Content="Set"
                    Click="Set_Click"
                    Width="100"
                    Height="35"
                    FontSize="14"
                    Margin="10,0,10,0"
                    HorizontalAlignment="Center"/>
            <Button Name="Done"
                    Content="Done"
                    Click="Done_Click"
                    Width="100"
                    Height="35"
                    FontSize="14"
                    Margin="10,0,10,0"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
