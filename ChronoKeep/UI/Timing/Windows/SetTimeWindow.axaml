<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Chronokeep.UI.Timing.Windows.SetTimeWindow"
        Background="{DynamicResource PrimaryBackground}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen"
        Title="Set Time"
        Width="300"
        CanResize="False"
        SizeToContent="Height"
        Topmost="True"
        Closing="Window_Closing">
    <StackPanel Margin="10,30,10,10"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Name="MainPanel">
        <TextBlock Text="Set Time To"
                   FontSize="18"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
        <RadioButton Name="NowTimeRadioButton"
                     Content="Now"
                     GroupName="TimeGroup"
                     FontSize="14"
                     IsChecked="True"
                     Margin="10,5,10,5"
                     VerticalContentAlignment="Center"/>
        <RadioButton Name="SpecificTimeRadioButton"
                     GroupName="TimeGroup"
                     Margin="10,5,10,5"
                     HorizontalAlignment="Stretch"
                     VerticalContentAlignment="Center">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <MaskedTextBox Grid.Column="0"
                               Mask="90/90/0000"
                               Name="SpecificDateBox"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               FontSize="14"/>
                <MaskedTextBox Grid.Column="1"
                               Name="SpecificTimeBox"
                               FontSize="14"
                               Margin="10,0,0,0"
                               Mask="00:00:00.000"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"/>
            </Grid>
        </RadioButton>
        <StackPanel Margin="0,10,0,0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <ToggleSwitch Name="SetAllCheckBox"
                          OnContent=""
                          OffContent=""
                          FontSize="14"
                          Margin="10,-7,-7,-7"
                          VerticalAlignment="Center"/>
            <Label Content="Set all connected readers" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Name="CurrentTimeLabel"
                   FontSize="14"
                   Margin="10,10,10,5"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="False"
                   />
        <TextBlock Name="TimeLabel"
                   FontSize="14"
                   Margin="10,5"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="False"
                   />
        <Grid Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Name="Check"
                    Content="Get Time"
                    Click="Check_Click"
                    Height="35"
                    FontSize="14"
                    Margin="10,5,3,5"
                    HorizontalAlignment="Stretch"/>
            <Button Grid.Column="1"
                    Name="Set"
                    Content="Set Time"
                    Click="Set_Click"
                    Height="35"
                    FontSize="14"
                    Margin="7,5,7,5"
                    HorizontalAlignment="Stretch"/>
            <Button Grid.Column="2" 
                    Name="Done"
                    Content="Done"
                    Click="Done_Click"
                    Height="35"
                    FontSize="14"
                    Margin="3,5,10,5"
                    HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</Window>
