<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
        x:Class="Chronokeep.UI.Timing.Windows.WaveWindow"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Title="Set Wave Times"
        Width="300"
        Height="300"
        CanResize="False"
        SizeToContent="Height"
        Closing="Window_Closing">
    <Grid Margin="0,35,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox Name="WaveList"
                 Grid.Row="0"
                 BorderThickness="0"
                 Margin="15,0,15,10"
                 KeyboardNavigation.TabNavigation="Continue"/>
        <DockPanel Grid.Row="1"
                   HorizontalAlignment="Center"
                   Margin="5">
            <RadioButton Name="NetTimeButton"
                         Content="Net Time"
                         GroupName="TimeGroup"
                         IsCheckedChanged="TimeofDayButton_Checked"
                         Width="100"
                         FontSize="14"
                         Margin="0,0,0,0"
                         VerticalContentAlignment="Center"/>
            <RadioButton Name="TimeofDayButton"
                         Content="Time of Day"
                         GroupName="TimeGroup"
                         IsCheckedChanged="TimeofDayButton_Checked"
                         Width="120"
                         FontSize="14"
                         Margin="0,0,0,0"
                         VerticalContentAlignment="Center"/>
        </DockPanel>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Button Name="SetButton"
                    Content="Set"
                    Click="SetButton_Click"
                    Width="100"
                    Height="35"
                    FontSize="14"
                    Margin="0,10,10,10"/>
            <Button Name="DoneButton"
                    Content="Cancel"
                    Click="DoneButton_Click"
                    Width="100"
                    Height="35"
                    FontSize="14"
                    Margin="10,10,0,10"/>
        </StackPanel>
    </Grid>
</Window>
