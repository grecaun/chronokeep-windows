<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="400"
        x:Class="Chronokeep.UI.EventWindows.NewEventWindow"
        Closing="Window_Closing"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        Width="400"
        Topmost="True"
        Title="New Event">
    <Window.Styles>
       <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="10"/> 
       </Style> 
    </Window.Styles>
    <StackPanel Margin="5,30,5,5">
        <DockPanel Margin="10,0,10,0">
            <TextBlock Text="Name"
                       Margin="10,10,5,10"
                       FontSize="16"
                       Width="80"
                       TextAlignment="Right"
                       VerticalAlignment="Center"/>
            <TextBox Name="nameBox"
                     FontSize="16"
                     Margin="5,10,10,10"
                     TextWrapping="Wrap"
                     KeyUp="Keyboard_Up"/>
        </DockPanel>
        <DockPanel Margin="10,0,10,0">
            <TextBlock Text="Year Code"
                       Margin="10,10,5,10"
                       FontSize="16"
                       Width="80"
                       TextAlignment="Right"
                       VerticalAlignment="Center"/>
            <TextBox Name="yearCodeBox"
                     FontSize="16"
                     Margin="5,10,10,10"
                     KeyUp="Keyboard_Up"/>
        </DockPanel>
        <DockPanel Margin="10,0,10,0">
            <TextBlock Text="Date"
                       Margin="10,10,5,10"
                       FontSize="16"
                       Width="80"
                       TextAlignment="Right"
                       VerticalAlignment="Center"/>
            <MaskedTextBox Name="datePicker"
                           Mask="90/90/0000"
                           KeyUp="Keyboard_Up"
                           Margin="5,10,10,10"
                           FontSize="16"/>
        </DockPanel>
        <AutoCompleteBox Name="oldEvent"
                         FontSize="16"
                         Width="250"
                         HorizontalAlignment="Center"
                         Margin="20,10,20,10"
                         PlaceholderText="Copy from old event?"
                         FilterMode="Contains"
                         >
            <AutoCompleteBox.InnerLeftContent>
               <PathIcon Data="{StaticResource search_regular}" Margin="7"/> 
            </AutoCompleteBox.InnerLeftContent>
        </AutoCompleteBox>
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <Button Content="Submit"
                    Click="Submit_Click"
                    Margin="20,10,10,15"
                    Width="120"
                    FontSize="16"
                    Height="35"/>
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    Margin="10,10,20,15"
                    Width="120"
                    FontSize="16"
                    Height="35"/>
        </StackPanel>
    </StackPanel>
</Window>
