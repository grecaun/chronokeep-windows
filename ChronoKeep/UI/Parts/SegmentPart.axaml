<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="450"
             x:Class="Chronokeep.UI.Parts.SegmentPart">
    <DockPanel Name="SegmentPanel"
                MaxWidth="1150"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
        <ComboBox Name="Location"
                    SelectionChanged="Location_Changed"
                    Width="140"
                    Height="35"
                    FontSize="16"
                    Margin="2,2,2,0"
                    VerticalAlignment="Center"/>
        <TextBox Name="SegName"
                    GotFocus="SelectAll"
                    Width="190"
                    Height="35"
                    FontSize="14"
                    Margin="2,2,2,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"/>
        <ComboBox Name="Occurrence"
                    Width="70"
                    Height="35"
                    FontSize="14"
                    Margin="2,2,2,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"/>
        <TextBox Name="CumDistance"
                    GotFocus="SelectAll"
                    TextInput="DoubleValidation"
                    Width="70"
                    Height="35"
                    FontSize="14"
                    Margin="2,2,2,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"/>
        <ComboBox Name="DistanceUnit"
                    Width="90"
                    Height="35"
                    FontSize="14"
                    Margin="2,2,2,0"
                    SelectedIndex="0"
                    VerticalContentAlignment="Center">
			<ComboBoxItem Content="Miles"/>
			<ComboBoxItem Content="Kilometers"/>
			<ComboBoxItem Content="Meters"/>
			<ComboBoxItem Content="Yards"/>
			<ComboBoxItem Content="Feet"/>
        </ComboBox>
        <TextBox Name="GPS"
                    GotFocus="SelectAll"
                    Width="190"
                    Height="35"
                    FontSize="14"
                    Margin="2,2,2,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"/>
        <TextBox Name="MapLink"
                    GotFocus="SelectAll"
                    Width="190"
                    Height="35"
                    FontSize="14"
                    Margin="2,2,2,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"/>
        <Button Click="Remove_Click"
                Width="50"
                Height="35"
                Margin="2,2,2,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                VerticalContentAlignment="Center"
                HorizontalContentAlignment="Center">
            <PathIcon Data="{StaticResource delete_regular}"/>
        </Button>
    </DockPanel>
</UserControl>
