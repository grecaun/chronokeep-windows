<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Chronokeep.UI.ChipAssignment.BibChipAssociationWindow"
        Background="{DynamicResource PrimaryBackground}"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        Topmost="True"
        Closing="Window_Closing">
    <Grid Margin="0,30,0,0" Name="MainPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Name="SheetsContainer"
                    Grid.Row="0"
                    HorizontalAlignment="Center">
            <TextBlock Text="Please choose a sheet:"
                       FontSize="18"
                       Margin="10,10,10,5"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
            <ComboBox Name="SheetsBox"
                      SelectionChanged="SheetsBox_SelectionChanged"
                      TabIndex="1"
                      Margin="5"
                      HorizontalAlignment="Stretch"/>
        </StackPanel>
        <ListBox Grid.Row="1"
                 Name="headerListBox"
                 Margin="20,3"
                 KeyboardNavigation.TabNavigation="Continue"></ListBox>
        <StackPanel Grid.Row="2">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ToggleSwitch
                    Name="Headers"
                    IsChecked="True"
                    FontSize="15"
                    OnContent=""
                    OffContent=""
                    Margin="0,-7,-7,-7"
                    HorizontalAlignment="Center"
                    VerticalContentAlignment="Center"
                    />
                <Label Content="First Row Contains Headers"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Margin="0,5,0,10"
                        HorizontalAlignment="Center">
                <Button Name="Done"
                        Click="Done_Click"
                        Height="37"
                        Width="125"
                        Content="Done"
                        Margin="25,0,5,0"
                        HorizontalAlignment="Left"/>
                <Button Name="Cancel"
                        Click="Cancel_Click"
                        Height="37"
                        Width="125"
                        Content="Cancel"
                        Margin="5,0,25,0"
                        HorizontalAlignment="Right"
                        />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
