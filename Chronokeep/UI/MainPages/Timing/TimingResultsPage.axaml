<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:objects="using:Chronokeep.Objects"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Chronokeep.UI.MainPages.Timing.TimingResultsPage">
    <UserControl.Styles>
        <Style Selector="DataGrid">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
			<Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Styles>
    
    <DataGrid Name="updateListView" RowHeight="25">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Loc" Binding="{Binding LocationName}" Width="90" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Occ" Binding="{Binding Occurrence}" Width="35" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="System Time" Binding="{Binding SysTime}" Width="150" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="105" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Chip Time" Binding="{Binding ChipLapTime}" Width="105" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Bib" Binding="{Binding Bib}" Width="50" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Name" Binding="{Binding ParticipantName}" Width="150" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Pl" Binding="{Binding PlaceStr}" Width="40" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="G" Binding="{Binding PrettyGender}" Width="35" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="GP" Binding="{Binding GenderPlaceStr}" Width="40" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Age Grp" Binding="{Binding AgeGroupName}" Width="60" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="AP" Binding="{Binding AgePlaceStr}" Width="40" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Division" Binding="{Binding Division}" Width="100" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="DP" Binding="{Binding DivisionPlaceStr}" Width="35" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Distance" Binding="{Binding DistanceName}" Width="110" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="T" Binding="{Binding PrettyType}" Width="35" x:DataType="objects:TimeResult"/>
            <DataGridTextColumn Header="Segment" Binding="{Binding SegmentName}" Width="120" x:DataType="objects:TimeResult"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
