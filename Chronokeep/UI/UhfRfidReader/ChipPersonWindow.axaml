<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Chronokeep.UI.UhfRfidReader.ChipPersonWindow"
        Background="{DynamicResource PrimaryBackground}"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        KeyUp="Window_KeyUp"
        Topmost="True"
        Closing="Window_Closing">
    <Window.Styles>
        <Style Selector="WindowDrawnDecorations /template/ Button#PART_MaximizeButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Width" Value="0"/>
        </Style> 
        <Style Selector="WindowDrawnDecorations /template/ Button#PART_MinimizeButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Width" Value="0"/>
        </Style> 
    </Window.Styles>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="1"
                   Name="Unknown"
                   FontSize="60"
                   IsVisible="False"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
        <StackPanel Grid.Row="1"
                    Name="InfoHolder"
                    VerticalAlignment="Center">
            <TextBlock Name="Bib"
                       FontSize="20"
                       HorizontalAlignment="Center"/>
            <TextBlock Name="Chip"
                       FontSize="20"
                       HorizontalAlignment="Center"/>
            <TextBlock Name="PersonName"
                       FontSize="60"
                       HorizontalAlignment="Center"/>
            <TextBlock Name="AgeGender"
                       FontSize="60"
                       HorizontalAlignment="Center"/>
            <TextBlock Name="Distance"
                       FontSize="60"
                       Margin="0,0,0,40"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
