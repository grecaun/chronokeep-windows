<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Chronokeep.UI.Timing.Windows.ClockControl"
        Background="{DynamicResource PrimaryBackground}"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Title="Remote Readers"
        MinHeight="200"
        MinWidth="1090"
        CanResize="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        Closed="Window_Closed">
    <StackPanel Margin="0,30,0,0" Name="MainPanel">
        <ListBox Name="clockListView" Margin="25,0,25,10"/>
        <TextBlock Name="CurrentTimeLabel"
                   FontSize="14"
                   IsVisible="False"
                   Margin="10,0,10,5"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
        <TextBlock Name="TimeLabel"
                   FontSize="14"
                   IsVisible="False"
                   Margin="10,5,10,10"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="AddButton"
                    Content="Add Clock"
                    Click="AddButton_Click"
                    Width="150"
                    Height="35"
                    Margin="0,0,5,10"
                    HorizontalAlignment="Center"/>
            <Button Name="CloseButton"
                    Content="Close"
                    Click="Close_Click"
                    Width="150"
                    Height="35"
                    Margin="5,0,0,10"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</Window>
